{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/files/upload/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/payments/webhook/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  }
}
